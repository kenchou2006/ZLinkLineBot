{
  "name": "zlink-line-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.local.toml",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply zlink-line-bot --local --config wrangler.local.toml",
    "db:migrate:remote": "wrangler d1 migrations apply zlink-line-bot --remote",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.105.0"
  }
}
